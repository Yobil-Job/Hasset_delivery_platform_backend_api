# ============================================
# Environment Variables Configuration
# ============================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env file to version control (it's already in .gitignore)

# ============================================
# JWT Configuration
# ============================================
# JWT secret key (minimum 32 characters for HS256 security)
JWT_SECRET=your-jwt-secret-key-minimum-32-characters-long

# JWT token expiration times (in milliseconds)
# Access token: 30 minutes (1800000 ms)
JWT_EXPIRATION=1800000
# Refresh token: 7 days (604800000 ms)
JWT_REFRESH_EXPIRATION=604800000

# ============================================
# Email Configuration (Gmail SMTP)
# ============================================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=465
# Your Gmail address
MAIL_USERNAME=your-email@gmail.com
# Your Gmail App Password (not your regular password)
# Generate one at: https://myaccount.google.com/apppasswords
MAIL_PASSWORD=your-gmail-app-password
# Email address to send emails from
MAIL_FROM=your-email@gmail.com
# Admin email address
MAIL_ADMIN=admin@yourdomain.com

# ============================================
# Redis Configuration
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
# Redis password (leave empty if no password)
REDIS_PASSWORD=
# Enable SSL for Redis (true/false)
REDIS_SSL_ENABLED=false

# ============================================
# Chapa Payment Configuration
# ============================================
# Get your keys from: https://dashboard.chapa.co
CHAPA_SECRET=sk_test_your_chapa_secret_key_here
CHAPA_PUBLIC=pk_test_your_chapa_public_key_here
# Payment mode: SANDBOX or LIVE
CHAPA_MODE=SANDBOX
CHAPA_BASE_URL=https://api.chapa.co/v1
# Payment return URL (where users are redirected after payment)
PAYMENT_RETURN_URL=http://localhost:3000/payments/result
# Payment webhook URL (where Chapa sends payment notifications)
PAYMENT_NOTIFY_URL=http://localhost:8080/api/payments/webhook

# ============================================
# Cloudinary Configuration
# ============================================
# Get your credentials from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# ============================================
# CORS Configuration
# ============================================
# Comma-separated list of allowed origins
# Example: CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
